# Required. Primary cert CN (MX hostname). Must match a live/<SERVER_HOSTNAME>/
# directory under /etc/letsencrypt once the cert has been issued.
SERVER_HOSTNAME=mx.taram.ca

# Recommended. Space-separated compose service names to SIGHUP after each
# successful renewal.
RELOAD_SERVICES=postfix

# Set to 1 to generate /etc/letsencrypt/dhparams.pem (2048-bit) on first
# renewal. Postfix references this file for DHE ciphers (needed for SMTP
# interop with older MTAs).
GENERATE_DHPARAMS=1

# Comma-separated list of domains to accept inbound mail for.
RELAY_DOMAINS=taram.ca

# Hostname or IP of the downstream mail server to relay inbound mail to.
RELAY_HOST=

# SMTP auth credentials for authenticated submission on port 587. Set
# SUBMISSION_PASS in your local .env (never commit it).
SUBMISSION_USER=
#SUBMISSION_PASS=

# SMTP bindings.
SMTP_PORT=25
SUBMISSION_PORT=587

# COMPOSE_PROJECT_NAME is set automatically by docker compose (defaults to the
# project directory name). Override it here only if you need a non-default
# name — docker-reload.py uses it to locate sibling containers.
#COMPOSE_PROJECT_NAME=taramx

# Internal IPv4 /24 subnet, format n.n.n (expands to n.n.n.0/24).
# Use a private range: https://en.wikipedia.org/wiki/Private_network#Private_IPv4_addresses
IPV4_NETWORK=172.22.2

# Internal IPv6 /64 subnet.
IPV6_NETWORK=fd00:taramx::
